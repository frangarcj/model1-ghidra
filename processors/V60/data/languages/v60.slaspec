# F1 format
:OUT.w op_m0_w, f_reg is op=0x25; f_type=0 & m2_flag=1 & m1_flag=0 & f_reg; op_m0_w { f_reg = op_m0_w; }
:OUT.w op_m1_w, f_reg is op=0x25; f_type=0 & m2_flag=1 & m1_flag=1 & f_reg; op_m1_w { f_reg = op_m1_w; }
:OUT.w f_reg, op_m0_w is op=0x25; f_type=0 & m2_flag=0 & m1_flag=0 & f_reg; op_m0_w { op_m0_w = f_reg; }
:OUT.w f_reg, op_m1_w is op=0x25; f_type=0 & m2_flag=0 & m1_flag=1 & f_reg; op_m1_w { op_m1_w = f_reg; }
