:MOVEA.w op_m1_w, op2_m0_w is op=0x44; f_type=1 & m1_flag=1 & m2_flag=0; op_m1_w; op2_m0_w { op2_m0_w = &op_m1_w; }
:MOVEA.w op_m1_w, op2_m1_w is op=0x44; f_type=1 & m1_flag=1 & m2_flag=1; op_m1_w; op2_m1_w { op2_m1_w = &op_m1_w; }

# --- Decrement and Branch (C6/C7) ---
:DBV    mod_reg, br_target16 is op=0xC6; mod_mode=0 & mod_reg; br_target16 { mod_reg = mod_reg - 1; if (mod_reg != 0 && (PSW & 0x01) != 0) goto br_target16; }
:DBL    mod_reg, br_target16 is op=0xC6; mod_mode=1 & mod_reg; br_target16 { mod_reg = mod_reg - 1; if (mod_reg != 0 && (PSW & 0x08) != 0) goto br_target16; }
:DBE    mod_reg, br_target16 is op=0xC6; mod_mode=2 & mod_reg; br_target16 { mod_reg = mod_reg - 1; if (mod_reg != 0 && (PSW & 0x02) != 0) goto br_target16; }
:DBNH   mod_reg, br_target16 is op=0xC6; mod_mode=3 & mod_reg; br_target16 { mod_reg = mod_reg - 1; if (mod_reg != 0 && (PSW & 0x0a) != 0) goto br_target16; }
:DBN    mod_reg, br_target16 is op=0xC6; mod_mode=4 & mod_reg; br_target16 { mod_reg = mod_reg - 1; if (mod_reg != 0 && (PSW & 0x04) != 0) goto br_target16; }
