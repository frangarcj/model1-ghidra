:AND.h op_m1_h, op2_m1_h is op=0xa2; f_type=1 & m1_flag=1 & m2_flag=1; op_m1_h; op2_m1_h { op2_m1_h = op_m1_h & op2_m1_h; }

# --- AND.w ---
# F1 format
:AND.w op_m0_w, f_reg is op=0xa4; f_type=0 & m2_flag=1 & m1_flag=0 & f_reg; op_m0_w { f_reg = op_m0_w & f_reg; }
:AND.w op_m1_w, f_reg is op=0xa4; f_type=0 & m2_flag=1 & m1_flag=1 & f_reg; op_m1_w { f_reg = op_m1_w & f_reg; }
:AND.w f_reg, op_m0_w is op=0xa4; f_type=0 & m2_flag=0 & m1_flag=0 & f_reg; op_m0_w { op_m0_w = op_m0_w & f_reg; }
:AND.w f_reg, op_m1_w is op=0xa4; f_type=0 & m2_flag=0 & m1_flag=1 & f_reg; op_m1_w { op_m1_w = op_m1_w & f_reg; }
# F2 format
:AND.w op_m0_w, op2_m0_w is op=0xa4; f_type=1 & m1_flag=0 & m2_flag=0; op_m0_w; op2_m0_w { op2_m0_w = op_m0_w & op2_m0_w; }
:AND.w op_m0_w, op2_m1_w is op=0xa4; f_type=1 & m1_flag=0 & m2_flag=1; op_m0_w; op2_m1_w { op2_m1_w = op_m0_w & op2_m1_w; }
:AND.w op_m1_w, op2_m0_w is op=0xa4; f_type=1 & m1_flag=1 & m2_flag=0; op_m1_w; op2_m0_w { op2_m0_w = op_m1_w & op2_m0_w; }
:AND.w op_m1_w, op2_m1_w is op=0xa4; f_type=1 & m1_flag=1 & m2_flag=1; op_m1_w; op2_m1_w { op2_m1_w = op_m1_w & op2_m1_w; }

# --- OR.b ---
# F1 format
:OR.b op_m0_b, f_reg_b is op=0x88; f_type=0 & m2_flag=1 & m1_flag=0 & f_reg_b; op_m0_b { f_reg_b = op_m0_b | f_reg_b; }
:OR.b op_m1_b, f_reg_b is op=0x88; f_type=0 & m2_flag=1 & m1_flag=1 & f_reg_b; op_m1_b { f_reg_b = op_m1_b | f_reg_b; }
:OR.b f_reg_b, op_m0_b is op=0x88; f_type=0 & m2_flag=0 & m1_flag=0 & f_reg_b; op_m0_b { op_m0_b = op_m0_b | f_reg_b; }
:OR.b f_reg_b, op_m1_b is op=0x88; f_type=0 & m2_flag=0 & m1_flag=1 & f_reg_b; op_m1_b { op_m1_b = op_m1_b | f_reg_b; }
# F2 format
:OR.b op_m0_b, op2_m0_b is op=0x88; f_type=1 & m1_flag=0 & m2_flag=0; op_m0_b; op2_m0_b { op2_m0_b = op_m0_b | op2_m0_b; }
:OR.b op_m0_b, op2_m1_b is op=0x88; f_type=1 & m1_flag=0 & m2_flag=1; op_m0_b; op2_m1_b { op2_m1_b = op_m0_b | op2_m1_b; }
:OR.b op_m1_b, op2_m0_b is op=0x88; f_type=1 & m1_flag=1 & m2_flag=0; op_m1_b; op2_m0_b { op2_m0_b = op_m1_b | op2_m0_b; }
:OR.b op_m1_b, op2_m1_b is op=0x88; f_type=1 & m1_flag=1 & m2_flag=1; op_m1_b; op2_m1_b { op2_m1_b = op_m1_b | op2_m1_b; }

# --- OR.h ---
# F1 format
:OR.h op_m0_h, f_reg_h is op=0x8a; f_type=0 & m2_flag=1 & m1_flag=0 & f_reg_h; op_m0_h { f_reg_h = op_m0_h | f_reg_h; }
:OR.h op_m1_h, f_reg_h is op=0x8a; f_type=0 & m2_flag=1 & m1_flag=1 & f_reg_h; op_m1_h { f_reg_h = op_m1_h | f_reg_h; }
:OR.h f_reg_h, op_m0_h is op=0x8a; f_type=0 & m2_flag=0 & m1_flag=0 & f_reg_h; op_m0_h { op_m0_h = op_m0_h | f_reg_h; }
:OR.h f_reg_h, op_m1_h is op=0x8a; f_type=0 & m2_flag=0 & m1_flag=1 & f_reg_h; op_m1_h { op_m1_h = op_m1_h | f_reg_h; }
# F2 format
:OR.h op_m0_h, op2_m0_h is op=0x8a; f_type=1 & m1_flag=0 & m2_flag=0; op_m0_h; op2_m0_h { op2_m0_h = op_m0_h | op2_m0_h; }
:OR.h op_m0_h, op2_m1_h is op=0x8a; f_type=1 & m1_flag=0 & m2_flag=1; op_m0_h; op2_m1_h { op2_m1_h = op_m0_h | op2_m1_h; }
:OR.h op_m1_h, op2_m0_h is op=0x8a; f_type=1 & m1_flag=1 & m2_flag=0; op_m1_h; op2_m0_h { op2_m0_h = op_m1_h | op2_m0_h; }
:OR.h op_m1_h, op2_m1_h is op=0x8a; f_type=1 & m1_flag=1 & m2_flag=1; op_m1_h; op2_m1_h { op2_m1_h = op_m1_h | op2_m1_h; }

# --- OR.w ---
# F1 format
:OR.w op_m0_w, f_reg is op=0x8c; f_type=0 & m2_flag=1 & m1_flag=0 & f_reg; op_m0_w { f_reg = op_m0_w | f_reg; }
:OR.w op_m1_w, f_reg is op=0x8c; f_type=0 & m2_flag=1 & m1_flag=1 & f_reg; op_m1_w { f_reg = op_m1_w | f_reg; }
:OR.w f_reg, op_m0_w is op=0x8c; f_type=0 & m2_flag=0 & m1_flag=0 & f_reg; op_m0_w { op_m0_w = op_m0_w | f_reg; }
:OR.w f_reg, op_m1_w is op=0x8c; f_type=0 & m2_flag=0 & m1_flag=1 & f_reg; op_m1_w { op_m1_w = op_m1_w | f_reg; }
# F2 format
:OR.w op_m0_w, op2_m0_w is op=0x8c; f_type=1 & m1_flag=0 & m2_flag=0; op_m0_w; op2_m0_w { op2_m0_w = op_m0_w | op2_m0_w; }
:OR.w op_m0_w, op2_m1_w is op=0x8c; f_type=1 & m1_flag=0 & m2_flag=1; op_m0_w; op2_m1_w { op2_m1_w = op_m0_w | op2_m1_w; }
:OR.w op_m1_w, op2_m0_w is op=0x8c; f_type=1 & m1_flag=1 & m2_flag=0; op_m1_w; op2_m0_w { op2_m0_w = op_m1_w | op2_m0_w; }
:OR.w op_m1_w, op2_m1_w is op=0x8c; f_type=1 & m1_flag=1 & m2_flag=1; op_m1_w; op2_m1_w { op2_m1_w = op_m1_w | op2_m1_w; }

# --- XOR.b ---
# F1 format
:XOR.b op_m0_b, f_reg_b is op=0xb0; f_type=0 & m2_flag=1 & m1_flag=0 & f_reg_b; op_m0_b { f_reg_b = op_m0_b ^ f_reg_b; }
:XOR.b op_m1_b, f_reg_b is op=0xb0; f_type=0 & m2_flag=1 & m1_flag=1 & f_reg_b; op_m1_b { f_reg_b = op_m1_b ^ f_reg_b; }
:XOR.b f_reg_b, op_m0_b is op=0xb0; f_type=0 & m2_flag=0 & m1_flag=0 & f_reg_b; op_m0_b { op_m0_b = op_m0_b ^ f_reg_b; }
:XOR.b f_reg_b, op_m1_b is op=0xb0; f_type=0 & m2_flag=0 & m1_flag=1 & f_reg_b; op_m1_b { op_m1_b = op_m1_b ^ f_reg_b; }
# F2 format
:XOR.b op_m0_b, op2_m0_b is op=0xb0; f_type=1 & m1_flag=0 & m2_flag=0; op_m0_b; op2_m0_b { op2_m0_b = op_m0_b ^ op2_m0_b; }
:XOR.b op_m0_b, op2_m1_b is op=0xb0; f_type=1 & m1_flag=0 & m2_flag=1; op_m0_b; op2_m1_b { op2_m1_b = op_m0_b ^ op2_m1_b; }
:XOR.b op_m1_b, op2_m0_b is op=0xb0; f_type=1 & m1_flag=1 & m2_flag=0; op_m1_b; op2_m0_b { op2_m0_b = op_m1_b ^ op2_m0_b; }
:XOR.b op_m1_b, op2_m1_b is op=0xb0; f_type=1 & m1_flag=1 & m2_flag=1; op_m1_b; op2_m1_b { op2_m1_b = op_m1_b ^ op2_m1_b; }

# --- XOR.h ---
# F1 format
:XOR.h op_m0_h, f_reg_h is op=0xb2; f_type=0 & m2_flag=1 & m1_flag=0 & f_reg_h; op_m0_h { f_reg_h = op_m0_h ^ f_reg_h; }
:XOR.h op_m1_h, f_reg_h is op=0xb2; f_type=0 & m2_flag=1 & m1_flag=1 & f_reg_h; op_m1_h { f_reg_h = op_m1_h ^ f_reg_h; }
:XOR.h f_reg_h, op_m0_h is op=0xb2; f_type=0 & m2_flag=0 & m1_flag=0 & f_reg_h; op_m0_h { op_m0_h = op_m0_h ^ f_reg_h; }
:XOR.h f_reg_h, op_m1_h is op=0xb2; f_type=0 & m2_flag=0 & m1_flag=1 & f_reg_h; op_m1_h { op_m1_h = op_m1_h ^ f_reg_h; }
# F2 format
:XOR.h op_m0_h, op2_m0_h is op=0xb2; f_type=1 & m1_flag=0 & m2_flag=0; op_m0_h; op2_m0_h { op2_m0_h = op_m0_h ^ op2_m0_h; }
:XOR.h op_m0_h, op2_m1_h is op=0xb2; f_type=1 & m1_flag=0 & m2_flag=1; op_m0_h; op2_m1_h { op2_m1_h = op_m0_h ^ op2_m1_h; }
:XOR.h op_m1_h, op2_m0_h is op=0xb2; f_type=1 & m1_flag=1 & m2_flag=0; op_m1_h; op2_m0_h { op2_m0_h = op_m1_h ^ op2_m0_h; }
:XOR.h op_m1_h, op2_m1_h is op=0xb2; f_type=1 & m1_flag=1 & m2_flag=1; op_m1_h; op2_m1_h { op2_m1_h = op_m1_h ^ op2_m1_h; }

# --- XOR.w ---
# F1 format
:XOR.w op_m0_w, f_reg is op=0xb4; f_type=0 & m2_flag=1 & m1_flag=0 & f_reg; op_m0_w { f_reg = op_m0_w ^ f_reg; }
:XOR.w op_m1_w, f_reg is op=0xb4; f_type=0 & m2_flag=1 & m1_flag=1 & f_reg; op_m1_w { f_reg = op_m1_w ^ f_reg; }
:XOR.w f_reg, op_m0_w is op=0xb4; f_type=0 & m2_flag=0 & m1_flag=0 & f_reg; op_m0_w { op_m0_w = op_m0_w ^ f_reg; }
:XOR.w f_reg, op_m1_w is op=0xb4; f_type=0 & m2_flag=0 & m1_flag=1 & f_reg; op_m1_w { op_m1_w = op_m1_w ^ f_reg; }
# F2 format
:XOR.w op_m0_w, op2_m0_w is op=0xb4; f_type=1 & m1_flag=0 & m2_flag=0; op_m0_w; op2_m0_w { op2_m0_w = op_m0_w ^ op2_m0_w; }
:XOR.w op_m0_w, op2_m1_w is op=0xb4; f_type=1 & m1_flag=0 & m2_flag=1; op_m0_w; op2_m1_w { op2_m1_w = op_m0_w ^ op2_m1_w; }
:XOR.w op_m1_w, op2_m0_w is op=0xb4; f_type=1 & m1_flag=1 & m2_flag=0; op_m1_w; op2_m0_w { op2_m0_w = op_m1_w ^ op2_m0_w; }
:XOR.w op_m1_w, op2_m1_w is op=0xb4; f_type=1 & m1_flag=1 & m2_flag=1; op_m1_w; op2_m1_w { op2_m1_w = op_m1_w ^ op2_m1_w; }

# --- INC ---
:INC.b  op_m0_b       is op=0xd8; op_m0_b { op_m0_b = op_m0_b + 1; }
:INC.b  op_m1_b       is op=0xd9; op_m1_b { op_m1_b = op_m1_b + 1; }
:INC.h  op_m0_h       is op=0xda; op_m0_h { op_m0_h = op_m0_h + 1; }
:INC.h  op_m1_h       is op=0xdb; op_m1_h { op_m1_h = op_m1_h + 1; }
:INC.w  op_m0_w       is op=0xdc; op_m0_w { op_m0_w = op_m0_w + 1; }
:INC.w  op_m1_w       is op=0xdd; op_m1_w { op_m1_w = op_m1_w + 1; }

# --- DEC ---
:DEC.b  op_m0_b       is op=0xd0; op_m0_b { op_m0_b = op_m0_b - 1; }
:DEC.b  op_m1_b       is op=0xd1; op_m1_b { op_m1_b = op_m1_b - 1; }
:DEC.h  op_m0_h       is op=0xd2; op_m0_h { op_m0_h = op_m0_h - 1; }
:DEC.h  op_m1_h       is op=0xd3; op_m1_h { op_m1_h = op_m1_h - 1; }
:DEC.w  op_m0_w       is op=0xd4; op_m0_w { op_m0_w = op_m0_w - 1; }
:DEC.w  op_m1_w       is op=0xd5; op_m1_w { op_m1_w = op_m1_w - 1; }

# --- PUSH / POP ---
:PUSH   op_m0_w       is op=0xee; op_m0_w { SP = SP - 4; *:4 SP = op_m0_w; }
:PUSH   op_m1_w       is op=0xef; op_m1_w { SP = SP - 4; *:4 SP = op_m1_w; }
:POP    op_m0_w       is op=0xe6; op_m0_w { op_m0_w = *:4 SP; SP = SP + 4; }
:POP    op_m1_w       is op=0xe7; op_m1_w { op_m1_w = *:4 SP; SP = SP + 4; }

# --- CALL ---
# F1 format
:CALL op_m0_w, f_reg is op=0x49; f_type=0 & m2_flag=1 & m1_flag=0 & f_reg; op_m0_w {
    SP = SP - 4;
    *:4 SP = AP;
    AP = f_reg;
    SP = SP - 4;
    *:4 SP = inst_next;
    call op_m0_w;
}
:CALL op_m1_w, f_reg is op=0x49; f_type=0 & m2_flag=1 & m1_flag=1 & f_reg; op_m1_w {
    SP = SP - 4;
    *:4 SP = AP;
    AP = f_reg;
    SP = SP - 4;
    *:4 SP = inst_next;
    call op_m1_w;
}
:CALL f_reg, op_m0_w is op=0x49; f_type=0 & m2_flag=0 & m1_flag=0 & f_reg; op_m0_w {
    SP = SP - 4;
    *:4 SP = AP;
    AP = op_m0_w;
    SP = SP - 4;
    *:4 SP = inst_next;
    call [f_reg];
}
:CALL f_reg, op_m1_w is op=0x49; f_type=0 & m2_flag=0 & m1_flag=1 & f_reg; op_m1_w {
    SP = SP - 4;
    *:4 SP = AP;
    AP = op_m1_w;
    SP = SP - 4;
    *:4 SP = inst_next;
    call [f_reg];
}
# F2 format
:CALL op_m0_w, op2_m0_w is op=0x49; f_type=1 & m1_flag=0 & m2_flag=0; op_m0_w; op2_m0_w {
    SP = SP - 4;
    *:4 SP = AP;
    AP = op2_m0_w;
    SP = SP - 4;
    *:4 SP = inst_next;
    call op_m0_w;
}
:CALL op_m0_w, op2_m1_w is op=0x49; f_type=1 & m1_flag=0 & m2_flag=1; op_m0_w; op2_m1_w {
    SP = SP - 4;
    *:4 SP = AP;
    AP = op2_m1_w;
    SP = SP - 4;
    *:4 SP = inst_next;
    call op_m0_w;
}
:CALL op_m1_w, op2_m0_w is op=0x49; f_type=1 & m1_flag=1 & m2_flag=0; op_m1_w; op2_m0_w {
    SP = SP - 4;
    *:4 SP = AP;
    AP = op2_m0_w;
    SP = SP - 4;
    *:4 SP = inst_next;
    call op_m1_w;
}
:CALL op_m1, op2_m1_w is op=0x49; f_type=1 & m1_flag=1 & m2_flag=1; op_m1; op2_m1_w {
    SP = SP - 4;
    *:4 SP = AP;
    AP = op2_m1_w;
    SP = SP - 4;
    *:4 SP = inst_next;
    call [op_m1];
}
:JMP    op_m0         is op=0xd6; op_m0 { goto [op_m0]; }
:JMP    op_m1         is op=0xd7; op_m1 { goto [op_m1]; }
:RET    op_m0_h       is op=0xe2; op_m0_h {
    local target:4 = *:4 SP;
    SP = SP + 4;
    AP = *:4 SP;
    SP = SP + 4;
    SP = SP + zext(op_m0_h);
    return [target];
}
:RET    op_m1_h       is op=0xe3; op_m1_h {
    local target:4 = *:4 SP;
    SP = SP + 4;
    AP = *:4 SP;
    SP = SP + 4;
    SP = SP + zext(op_m1_h);
    return [target];
}
:BSR    br_target16   is op=0x48; br_target16 {
    SP = SP - 4;
    *:4 SP = inst_next;
    call br_target16;
}
:JSR    op_m0         is op=0xe8; op_m0 {
    SP = SP - 4;
    *:4 SP = inst_next;
    call [op_m0];
}
:JSR    op_m1         is op=0xe9; op_m1 {
    SP = SP - 4;
    *:4 SP = inst_next;
    call [op_m1];
}

# --- PREPARE / DISPOSE / NOP / HALT / RSR ---
:PREPARE op_m0_w      is op=0xde; op_m0_w {
    SP = SP - 4;
    *:4 SP = AP;
    FP = SP;
    AP = FP + 8;
    SP = SP - op_m0_w;
}
:PREPARE op_m1_w      is op=0xdf; op_m1_w {
    SP = SP - 4;
    *:4 SP = AP;
    FP = SP;
    AP = FP + 8;
    SP = SP - op_m1_w;
}
:DISPOSE              is op=0xcc {
    SP = FP;
    FP = *:4 SP;
    SP = SP + 4;
}
:NOP                  is op=0xcd {}
:HALT                 is op=0x00 {}
:RSR                  is op=0xca {
    local target:4 = *:4 SP;
    SP = SP + 4;
    return [target];
}

# --- Conditional Branches (8-bit) ---
:BV     br_target8    is op=0x60; br_target8 { if ((PSW & 0x01) != 0) goto br_target8; } # Overflow
:BNV    br_target8    is op=0x61; br_target8 { if ((PSW & 0x01) == 0) goto br_target8; }
:BL     br_target8    is op=0x62; br_target8 { if ((PSW & 0x08) != 0) goto br_target8; } # Carry/Less (Unsigned)
:BNL    br_target8    is op=0x63; br_target8 { if ((PSW & 0x08) == 0) goto br_target8; }
:BE     br_target8    is op=0x64; br_target8 { if ((PSW & 0x02) != 0) goto br_target8; } # Zero/Equal
:BNE    br_target8    is op=0x65; br_target8 { if ((PSW & 0x02) == 0) goto br_target8; }
:BNH    br_target8    is op=0x66; br_target8 { if ((PSW & 0x0a) != 0) goto br_target8; } # Z or CY
:BH     br_target8    is op=0x67; br_target8 { if ((PSW & 0x0a) == 0) goto br_target8; }
:BN     br_target8    is op=0x68; br_target8 { if ((PSW & 0x04) != 0) goto br_target8; } # Negative/Sign
:BP     br_target8    is op=0x69; br_target8 { if ((PSW & 0x04) == 0) goto br_target8; }
:BR     br_target8    is op=0x6a; br_target8 { goto br_target8; }
:BLT    br_target8    is op=0x6c; br_target8 { if ((PSW & 0x10) != 0) goto br_target8; } # Signed Less Than
:BGE    br_target8    is op=0x6d; br_target8 { if ((PSW & 0x10) == 0) goto br_target8; }
:BLE    br_target8    is op=0x6e; br_target8 { if ((PSW & 0x12) != 0) goto br_target8; } # Z or Signed Less Than
:BGT    br_target8    is op=0x6f; br_target8 { if ((PSW & 0x12) == 0) goto br_target8; }

# --- Conditional Branches (16-bit) ---
:BV     br_target16   is op=0x70; br_target16 { if ((PSW & 0x01) != 0) goto br_target16; }
:BNV    br_target16   is op=0x71; br_target16 { if ((PSW & 0x01) == 0) goto br_target16; }
:BL     br_target16   is op=0x72; br_target16 { if ((PSW & 0x08) != 0) goto br_target16; }
