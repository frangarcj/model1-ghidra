# Sleigh specification for NEC V60 CPU

define endian=little;
define alignment=1;

define space ram type=ram_space size=4 default;
define space register type=register_space size=4;

# Register definitions
define register offset=0 size=4 [
	R0  R1  R2  R3  R4  R5  R6  R7
	R8  R9  R10 R11 R12 R13 R14 R15
	R16 R17 R18 R19 R20 R21 R22 R23
	R24 R25 R26 R27 R28 AP  FP  SP
	PC  PSW
];

define register offset=0 size=1 [
	R0b  _ _ _ R1b  _ _ _ R2b  _ _ _ R3b  _ _ _
	R4b  _ _ _ R5b  _ _ _ R6b  _ _ _ R7b  _ _ _
	R8b  _ _ _ R9b  _ _ _ R10b _ _ _ R11b _ _ _
	R12b _ _ _ R13b _ _ _ R14b _ _ _ R15b _ _ _
	R16b _ _ _ R17b _ _ _ R18b _ _ _ R19b _ _ _
	R20b _ _ _ R21b _ _ _ R22b _ _ _ R23b _ _ _
	R24b _ _ _ R25b _ _ _ R26b _ _ _ R27b _ _ _
	R28b _ _ _ APb  _ _ _ FPb  _ _ _ SPb
];

define register offset=0 size=2 [
	R0h  _ R1h  _ R2h  _ R3h  _
	R4h  _ R5h  _ R6h  _ R7h  _
	R8h  _ R9h  _ R10h _ R11h _
	R12h _ R13h _ R14h _ R15h _
	R16h _ R17h _ R18h _ R19h _
	R20h _ R21h _ R22h _ R23h _
	R24h _ R25h _ R26h _ R27h _
	R28h _ APh  _ FPh  _ SPh
];

define register offset=256 size=4 [
    ISP L0SP L1SP L2SP L3SP SBR TR SYCW TKCW PIR PSW2
    ATBR0 ATLR0 ATBR1 ATLR1 ATBR2 ATLR2 ATBR3 ATLR3
    TRMODE ADTR0 ADTR1 ADTMR0 ADTMR1
];

# Tokens
define token opToken (8)
    op = (0, 7)
;

define token modCodeToken (8)
    f_type  = (7, 7)
    m1_flag = (6, 6)
    m2_flag = (5, 5)
    f_reg   = (0, 4)
    f_reg_b = (0, 4)
    f_reg_h = (0, 4)
;

define token modToken (8)
    mod_mode     = (5, 7)
    mod_reg      = (0, 4)
    mod_reg_b    = (0, 4)
    mod_reg_h    = (0, 4)
    mod_reg_bit4 = (4, 4)
    mod_reg_low4 = (0, 3)
;

define token mod2Token (8)
    mod2_mode     = (5, 7)
    mod2_reg      = (0, 4)
    mod2_reg_b    = (0, 4)
    mod2_reg_h    = (0, 4)
    mod2_reg_bit4 = (4, 4)
    mod2_reg_low4 = (0, 3)
;

define token f7FlagsToken (8)
    f7_m1 = (6, 6)
    f7_m2 = (5, 5)
    f7_sub = (0, 4)
;

define token f7OpToken (8)
    f7_op_reg_flag = (7, 7)
    f7_op_reg      = (0, 4)
    f7_op_imm      = (0, 7)
;

define token valToken8 (8)
    val8 = (0, 7)
    val8s = (0, 7) signed
;
define token valToken8_1 (8)
    val8_1 = (0, 7)
    val8s_1 = (0, 7) signed
;

define token valToken16 (16)
    val16 = (0, 15)
    val16s = (0, 15) signed
;
define token valToken16_1 (16)
    val16_1 = (0, 15)
    val16s_1 = (0, 15) signed
;

define token valToken32 (32)
    val32 = (0, 31)
    val32s = (0, 31) signed
;
define token valToken32_1 (32)
    val32_1 = (0, 31)
    val32s_1 = (0, 31) signed
;

define token relToken8 (8)
    rel8 = (0, 7) signed
;
define token relToken16 (16)
    rel16 = (0, 15) signed
;

# Attach register variables
attach variables [ f_reg mod_reg mod2_reg f7_op_reg ] [
	R0  R1  R2  R3  R4  R5  R6  R7
	R8  R9  R10 R11 R12 R13 R14 R15
	R16 R17 R18 R19 R20 R21 R22 R23
	R24 R25 R26 R27 R28 AP  FP  SP
];

attach variables [ f_reg_b mod_reg_b mod2_reg_b ] [
	R0b  R1b  R2b  R3b  R4b  R5b  R6b  R7b
	R8b  R9b  R10b R11b R12b R13b R14b R15b
	R16b R17b R18b R19b R20b R21b R22b R23b
	R24b R25b R26b R27b R28b APb  FPb  SPb
];

attach variables [ f_reg_h mod_reg_h mod2_reg_h ] [
	R0h  R1h  R2h  R3h  R4h  R5h  R6h  R7h
	R8h  R9h  R10h R11h R12h R13h R14h R15h
	R16h R17h R18h R19h R20h R21h R22h R23h
	R24h R25h R26h R27h R28h APh  FPh  SPh
];

# Branch target address mapping
br_target8: target is rel8 [ target = inst_start + rel8; ] { export *[ram]:4 target; }
br_target16: target is rel16 [ target = inst_start + rel16; ] { export *[ram]:4 target; }

f7_op: f7_op_reg is f7_op_reg_flag=1 & f7_op_reg { export f7_op_reg; }
f7_op: #f7_op_imm is f7_op_reg_flag=0 & f7_op_imm { local tmp:4 = f7_op_imm; export tmp; }

f7_op2: f7_op_reg is f7_op_reg_flag=1 & f7_op_reg { export f7_op_reg; }
f7_op2: #f7_op_imm is f7_op_reg_flag=0 & f7_op_imm { local tmp:4 = f7_op_imm; export tmp; }

# =====================================================================
# Addressing Modes - m = 0
# =====================================================================

op_m0: mod_reg is mod_mode=0 & mod_reg; val8s {
    local tmp:4 = mod_reg + sext(val8s:1);
    export tmp;
}
op_m0: mod_reg is mod_mode=1 & mod_reg; val16s {
    local tmp:4 = mod_reg + sext(val16s:2);
    export tmp;
}
op_m0: mod_reg is mod_mode=2 & mod_reg; val32s {
    local tmp:4 = mod_reg + val32s;
    export tmp;
}
op_m0: [mod_reg] is mod_mode=3 & mod_reg {
    local tmp:4 = mod_reg;
    export tmp;
}
op_m0: [mod_reg] is mod_mode=4 & mod_reg; val8s {
    local ptr:4 = mod_reg + sext(val8s:1);
    export ptr;
}
op_m0: [mod_reg] is mod_mode=5 & mod_reg; val16s {
    local ptr:4 = mod_reg + sext(val16s:2);
    export ptr;
}
op_m0: [mod_reg] is mod_mode=6 & mod_reg; val32s {
    local ptr:4 = mod_reg + val32s;
    export ptr;
}
op_m0: val8s["PC"] is mod_mode=7 & mod_reg_bit4=1 & mod_reg_low4=0; val8s {
    local tmp:4 = inst_start + sext(val8s:1);
    export tmp;
}
op_m0: val16s["PC"] is mod_mode=7 & mod_reg_bit4=1 & mod_reg_low4=1; val16s {
    local tmp:4 = inst_start + sext(val16s:2);
    export tmp;
}
op_m0: val32s["PC"] is mod_mode=7 & mod_reg_bit4=1 & mod_reg_low4=2; val32s {
    local tmp:4 = inst_start + val32s;
    export tmp;
}
op_m0: val32 is mod_mode=7 & mod_reg_bit4=1 & mod_reg_low4=3; val32 {
    local tmp:4 = val32;
    export tmp;
}
op_m0: [val8s["PC"]] is mod_mode=7 & mod_reg_bit4=1 & mod_reg_low4=8; val8s {
    local ptr:4 = inst_start + sext(val8s:1);
    local tmp:4 = *:4 ptr;
    export tmp;
}
op_m0: [val16s["PC"]] is mod_mode=7 & mod_reg_bit4=1 & mod_reg_low4=9; val16s {
    local ptr:4 = inst_start + sext(val16s:2);
    local tmp:4 = *:4 ptr;
    export tmp;
}
op_m0: [val32s["PC"]] is mod_mode=7 & mod_reg_bit4=1 & mod_reg_low4=10; val32s {
    local ptr:4 = inst_start + val32s;
    local tmp:4 = *:4 ptr;
    export tmp;
}
op_m0: [val32] is mod_mode=7 & mod_reg_bit4=1 & mod_reg_low4=11; val32 {
    local ptr:4 = *:4 val32:4;
    export ptr;
}
op_m0: val8s_1[val8s["PC"]] is mod_mode=7 & mod_reg_bit4=1 & mod_reg_low4=12; val8s; val8s_1 {
    local ptr:4 = inst_start + sext(val8s:1);
    local base:4 = *:4 ptr;
    local tmp:4 = base + sext(val8s_1:1);
    export tmp;
}
op_m0: val16s_1[val16s["PC"]] is mod_mode=7 & mod_reg_bit4=1 & mod_reg_low4=13; val16s; val16s_1 {
    local ptr:4 = inst_start + sext(val16s:2);
    local base:4 = *:4 ptr;
    local tmp:4 = base + sext(val16s_1:2);
    export tmp;
}
op_m0: val32s_1[val32s["PC"]] is mod_mode=7 & mod_reg_bit4=1 & mod_reg_low4=14; val32s; val32s_1 {
    local ptr:4 = inst_start + val32s;
    local base:4 = *:4 ptr;
    local tmp:4 = base + val32s_1;
    export tmp;
}

# =====================================================================
# Addressing Modes - m = 1
# =====================================================================

op_m1: val8s_1[val8s[mod_reg]] is mod_mode=0 & mod_reg; val8s; val8s_1 {
    local ptr:4 = mod_reg + sext(val8s:1);
    local base:4 = *:4 ptr;
    local tmp:4 = base + sext(val8s_1:1);
    export tmp;
}
op_m1: val16s_1[val16s[mod_reg]] is mod_mode=1 & mod_reg; val16s; val16s_1 {
    local ptr:4 = mod_reg + sext(val16s:2);
    local base:4 = *:4 ptr;
    local tmp:4 = base + sext(val16s_1:2);
    export tmp;
}
op_m1: val32s_1[val32s[mod_reg]] is mod_mode=2 & mod_reg; val32s; val32s_1 {
    local ptr:4 = mod_reg + val32s;
    local base:4 = *:4 ptr;
    local tmp:4 = base + val32s_1;
    export tmp;
}
op_m1: val8s[mod2_reg](mod_reg) is mod_mode=6 & mod_reg; mod2_mode=0 & mod2_reg; val8s {
    local tmp:4 = mod2_reg + sext(val8s:1) + mod_reg;
    export tmp;
}
op_m1: val16s[mod2_reg](mod_reg) is mod_mode=6 & mod_reg; mod2_mode=1 & mod2_reg; val16s {
    local tmp:4 = mod2_reg + sext(val16s:2) + mod_reg;
    export tmp;
}
op_m1: val32s[mod2_reg](mod_reg) is mod_mode=6 & mod_reg; mod2_mode=2 & mod2_reg; val32s {
    local tmp:4 = mod2_reg + val32s + mod_reg;
    export tmp;
}
op_m1: [mod2_reg](mod_reg) is mod_mode=6 & mod_reg; mod2_mode=3 & mod2_reg {
    local tmp:4 = mod2_reg + mod_reg;
    export tmp;
}
op_m1: [mod2_reg](mod_reg) is mod_mode=6 & mod_reg; mod2_mode=4 & mod2_reg; val8s {
    local ptr:4 = mod2_reg + sext(val8s:1);
    local base:4 = *:4 ptr;
    local tmp:4 = base + mod_reg;
    export tmp;
}
op_m1: [mod2_reg](mod_reg) is mod_mode=6 & mod_reg; mod2_mode=5 & mod2_reg; val16s {
    local ptr:4 = mod2_reg + sext(val16s:2);
    local base:4 = *:4 ptr;
    local tmp:4 = base + mod_reg;
    export tmp;
}
op_m1: [mod2_reg](mod_reg) is mod_mode=6 & mod_reg; mod2_mode=6 & mod2_reg; val32s {
    local ptr:4 = mod2_reg + val32s;
    local base:4 = *:4 ptr;
    local tmp:4 = base + mod_reg;
    export tmp;
}
op_m1: val8s["PC"](mod_reg) is mod_mode=6 & mod_reg; mod2_mode=7 & mod2_reg_bit4=1 & mod2_reg_low4=0; val8s {
    local tmp:4 = inst_start + sext(val8s:1) + mod_reg;
    export tmp;
}
op_m1: val16s["PC"](mod_reg) is mod_mode=6 & mod_reg; mod2_mode=7 & mod2_reg_bit4=1 & mod2_reg_low4=1; val16s {
    local tmp:4 = inst_start + sext(val16s:2) + mod_reg;
    export tmp;
}
op_m1: val32s["PC"](mod_reg) is mod_mode=6 & mod_reg; mod2_mode=7 & mod2_reg_bit4=1 & mod2_reg_low4=2; val32s {
    local tmp:4 = inst_start + val32s + mod_reg;
    export tmp;
}
op_m1: val32(mod_reg) is mod_mode=6 & mod_reg; mod2_mode=7 & mod2_reg_bit4=1 & mod2_reg_low4=3; val32 {
    local tmp:4 = val32 + mod_reg;
    export tmp;
}
op_m1: [val8s["PC"]](mod_reg) is mod_mode=6 & mod_reg; mod2_mode=7 & mod2_reg_bit4=1 & mod2_reg_low4=8; val8s {
    local ptr:4 = inst_start + sext(val8s:1);
    local base:4 = *:4 ptr;
    local tmp:4 = base + mod_reg;
    export tmp;
}
op_m1: [val16s["PC"]](mod_reg) is mod_mode=6 & mod_reg; mod2_mode=7 & mod2_reg_bit4=1 & mod2_reg_low4=9; val16s {
    local ptr:4 = inst_start + sext(val16s:2);
    local base:4 = *:4 ptr;
    local tmp:4 = base + mod_reg;
    export tmp;
}
op_m1: [val32s["PC"]](mod_reg) is mod_mode=6 & mod_reg; mod2_mode=7 & mod2_reg_bit4=1 & mod2_reg_low4=10; val32s {
    local ptr:4 = inst_start + val32s;
    local base:4 = *:4 ptr;
    local tmp:4 = base + mod_reg;
    export tmp;
}
op_m1: [val32](mod_reg) is mod_mode=6 & mod_reg; mod2_mode=7 & mod2_reg_bit4=1 & mod2_reg_low4=11; val32 {
    local ptr:4 = *:4 val32:4;
    local tmp:4 = ptr + mod_reg;
    export tmp;
}

# =====================================================================
# Size specific submode overrides (M0)
# =====================================================================

op_m0_b: op_m0 is op_m0 { export *:1 op_m0; }
op_m0_b: #mod_reg_low4 is mod_mode=7 & mod_reg_bit4=0 & mod_reg_low4 {
    local tmp:1 = mod_reg_low4;
    export tmp;
}
op_m0_b: #val8 is mod_mode=7 & mod_reg_bit4=1 & mod_reg_low4=4; val8 {
    local tmp:1 = val8;
    export tmp;
}

op_m0_h: op_m0 is op_m0 { export *:2 op_m0; }
op_m0_h: #mod_reg_low4 is mod_mode=7 & mod_reg_bit4=0 & mod_reg_low4 {
    local tmp:2 = mod_reg_low4;
    export tmp;
}
op_m0_h: #val16 is mod_mode=7 & mod_reg_bit4=1 & mod_reg_low4=4; val16 {
    local tmp:2 = val16;
    export tmp;
}

op_m0_w: op_m0 is op_m0 { export *:4 op_m0; }
op_m0_w: #mod_reg_low4 is mod_mode=7 & mod_reg_bit4=0 & mod_reg_low4 {
    local tmp:4 = mod_reg_low4;
    export tmp;
}
op_m0_w: #val32 is mod_mode=7 & mod_reg_bit4=1 & mod_reg_low4=4; val32 {
    local tmp:4 = val32;
    export tmp;
}

# =====================================================================
# Size specific submode overrides (M1)
# =====================================================================

op_m1_b: op_m1 is op_m1 { export *:1 op_m1; }
op_m1_b: mod_reg_b is mod_mode=3 & mod_reg_b { export mod_reg_b; }
op_m1_b: [mod_reg+] is mod_mode=4 & mod_reg {
    local tmp:4 = mod_reg;
    mod_reg = mod_reg + 1;
    export *:1 tmp;
}
op_m1_b: [-mod_reg] is mod_mode=5 & mod_reg {
    mod_reg = mod_reg - 1;
    local tmp:4 = mod_reg;
    export *:1 tmp;
}

op_m1_h: op_m1 is op_m1 { export *:2 op_m1; }
op_m1_h: mod_reg_h is mod_mode=3 & mod_reg_h { export mod_reg_h; }
op_m1_h: [mod_reg+] is mod_mode=4 & mod_reg {
    local tmp:4 = mod_reg;
    mod_reg = mod_reg + 2;
    export *:2 tmp;
}
op_m1_h: [-mod_reg] is mod_mode=5 & mod_reg {
    mod_reg = mod_reg - 2;
    local tmp:4 = mod_reg;
    export *:2 tmp;
}

op_m1_w: op_m1 is op_m1 { export *:4 op_m1; }
op_m1_w: mod_reg is mod_mode=3 & mod_reg { export mod_reg; }
op_m1_w: [mod_reg+] is mod_mode=4 & mod_reg {
    local tmp:4 = mod_reg;
    mod_reg = mod_reg + 4;
    export *:4 tmp;
}
op_m1_w: [-mod_reg] is mod_mode=5 & mod_reg {
    mod_reg = mod_reg - 4;
    local tmp:4 = mod_reg;
    export *:4 tmp;
}

# =====================================================================
# Operand Dispatchers based on mod_code flags
# =====================================================================

# =====================================================================
# Operand Wrapper Tables for the second operand in F2 format
# =====================================================================

op2_m0_b: op_m0_b is op_m0_b { export op_m0_b; }
op2_m1_b: op_m1_b is op_m1_b { export op_m1_b; }

op2_m0_h: op_m0_h is op_m0_h { export op_m0_h; }
op2_m1_h: op_m1_h is op_m1_h { export op_m1_h; }

op2_m0_w: op_m0_w is op_m0_w { export op_m0_w; }
op2_m1_w: op_m1_w is op_m1_w { export op_m1_w; }

# =====================================================================
# Instructions Definitions
# =====================================================================

# --- MOV.b ---
# F1 format: Reg/AM
:MOV.b op_m0_b, f_reg_b is op=0x09; f_type=0 & m2_flag=1 & m1_flag=0 & f_reg_b; op_m0_b { f_reg_b = op_m0_b; }
:MOV.b op_m1_b, f_reg_b is op=0x09; f_type=0 & m2_flag=1 & m1_flag=1 & f_reg_b; op_m1_b { f_reg_b = op_m1_b; }
:MOV.b f_reg_b, op_m0_b is op=0x09; f_type=0 & m2_flag=0 & m1_flag=0 & f_reg_b; op_m0_b { op_m0_b = f_reg_b; }
:MOV.b f_reg_b, op_m1_b is op=0x09; f_type=0 & m2_flag=0 & m1_flag=1 & f_reg_b; op_m1_b { op_m1_b = f_reg_b; }
# F2 format: AM/AM
:MOV.b op_m0_b, op2_m0_b is op=0x09; f_type=1 & m1_flag=0 & m2_flag=0; op_m0_b; op2_m0_b { op2_m0_b = op_m0_b; }
:MOV.b op_m0_b, op2_m1_b is op=0x09; f_type=1 & m1_flag=0 & m2_flag=1; op_m0_b; op2_m1_b { op2_m1_b = op_m0_b; }
:MOV.b op_m1_b, op2_m0_b is op=0x09; f_type=1 & m1_flag=1 & m2_flag=0; op_m1_b; op2_m0_b { op2_m0_b = op_m1_b; }
:MOV.b op_m1_b, op2_m1_b is op=0x09; f_type=1 & m1_flag=1 & m2_flag=1; op_m1_b; op2_m1_b { op2_m1_b = op_m1_b; }

# --- MOV.h ---
# F1 format
:MOV.h op_m0_h, f_reg_h is op=0x1b; f_type=0 & m2_flag=1 & m1_flag=0 & f_reg_h; op_m0_h { f_reg_h = op_m0_h; }
:MOV.h op_m1_h, f_reg_h is op=0x1b; f_type=0 & m2_flag=1 & m1_flag=1 & f_reg_h; op_m1_h { f_reg_h = op_m1_h; }
:MOV.h f_reg_h, op_m0_h is op=0x1b; f_type=0 & m2_flag=0 & m1_flag=0 & f_reg_h; op_m0_h { op_m0_h = f_reg_h; }
:MOV.h f_reg_h, op_m1_h is op=0x1b; f_type=0 & m2_flag=0 & m1_flag=1 & f_reg_h; op_m1_h { op_m1_h = f_reg_h; }
# F2 format
:MOV.h op_m0_h, op2_m0_h is op=0x1b; f_type=1 & m1_flag=0 & m2_flag=0; op_m0_h; op2_m0_h { op2_m0_h = op_m0_h; }
:MOV.h op_m0_h, op2_m1_h is op=0x1b; f_type=1 & m1_flag=0 & m2_flag=1; op_m0_h; op2_m1_h { op2_m1_h = op_m0_h; }
:MOV.h op_m1_h, op2_m0_h is op=0x1b; f_type=1 & m1_flag=1 & m2_flag=0; op_m1_h; op2_m0_h { op2_m0_h = op_m1_h; }
:MOV.h op_m1_h, op2_m1_h is op=0x1b; f_type=1 & m1_flag=1 & m2_flag=1; op_m1_h; op2_m1_h { op2_m1_h = op_m1_h; }

# --- MOV.w ---
# F1 format
:MOV.w op_m0_w, f_reg is op=0x2d; f_type=0 & m2_flag=1 & m1_flag=0 & f_reg; op_m0_w { f_reg = op_m0_w; }
:MOV.w op_m1_w, f_reg is op=0x2d; f_type=0 & m2_flag=1 & m1_flag=1 & f_reg; op_m1_w { f_reg = op_m1_w; }
:MOV.w f_reg, op_m0_w is op=0x2d; f_type=0 & m2_flag=0 & m1_flag=0 & f_reg; op_m0_w { op_m0_w = f_reg; }
:MOV.w f_reg, op_m1_w is op=0x2d; f_type=0 & m2_flag=0 & m1_flag=1 & f_reg; op_m1_w { op_m1_w = f_reg; }
# F2 format
:MOV.w op_m0_w, op2_m0_w is op=0x2d; f_type=1 & m1_flag=0 & m2_flag=0; op_m0_w; op2_m0_w { op2_m0_w = op_m0_w; }
:MOV.w op_m0_w, op2_m1_w is op=0x2d; f_type=1 & m1_flag=0 & m2_flag=1; op_m0_w; op2_m1_w { op2_m1_w = op_m0_w; }
