# --- MOVEA.w ---
# F1 format
:MOVEA.w op_m0_w, f_reg is op=0x44; f_type=0 & m2_flag=1 & m1_flag=0 & f_reg; op_m0_w { f_reg = &op_m0_w; }
:MOVEA.w op_m1_w, f_reg is op=0x44; f_type=0 & m2_flag=1 & m1_flag=1 & f_reg; op_m1_w { f_reg = &op_m1_w; }
