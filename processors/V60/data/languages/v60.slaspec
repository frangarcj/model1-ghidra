# --- UPDPSW.w ---
# F1 format
:UPDPSW.w op_m0_w, f_reg is op=0x13; f_type=0 & m2_flag=1 & m1_flag=0 & f_reg; op_m0_w {
    local mask:4 = f_reg & 0xFFFFFF;
    local val:4 = op_m0_w & 0xFFFFFF;
    PSW = (PSW & (~mask)) | (val & mask);
}
:UPDPSW.w op_m1_w, f_reg is op=0x13; f_type=0 & m2_flag=1 & m1_flag=1 & f_reg; op_m1_w {
