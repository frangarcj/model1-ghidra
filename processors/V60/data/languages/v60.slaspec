:OUT.w op_m1_w, op2_m0_w is op=0x25; f_type=1 & m1_flag=1 & m2_flag=0; op_m1_w; op2_m0_w { op2_m0_w = op_m1_w; }
:OUT.w op_m1_w, op2_m1_w is op=0x25; f_type=1 & m1_flag=1 & m2_flag=1; op_m1_w; op2_m1_w { op2_m1_w = op_m1_w; }

# --- TASI ---
:TASI op_m0_b is op=0xE0; op_m0_b {
    local tmp:1 = op_m0_b;
    op_m0_b = 0xff;
}
:TASI op_m1_b is op=0xE1; op_m1_b {
    local tmp:1 = op_m1_b;
    op_m1_b = 0xff;
}

# --- TESTB ---
:TESTB op_m0_b is op=0xf0; op_m0_b {
    local tmp:1 = op_m0_b;
}
:TESTB op_m1_b is op=0xf1; op_m1_b {
    local tmp:1 = op_m1_b;
}

# --- TESTH ---
:TESTH op_m0_h is op=0xf2; op_m0_h {
    local tmp:2 = op_m0_h;
}
:TESTH op_m1_h is op=0xf3; op_m1_h {
    local tmp:2 = op_m1_h;
}

# --- TESTW ---
:TESTW op_m0_w is op=0xf4; op_m0_w {
    local tmp:4 = op_m0_w;
}
:TESTW op_m1_w is op=0xf5; op_m1_w {
    local tmp:4 = op_m1_w;
}

# --- PUSHM / POPM ---
:PUSHM op_m0_w is op=0xec; op_m0_w {}
:PUSHM op_m1_w is op=0xed; op_m1_w {}
:POPM op_m1_w is op=0xe5; op_m1_w {}

# --- MOVEA.b ---
# F1 format
:MOVEA.b op_m0_b, f_reg is op=0x40; f_type=0 & m2_flag=1 & m1_flag=0 & f_reg; op_m0_b { f_reg = &op_m0_b; }
:MOVEA.b op_m1_b, f_reg is op=0x40; f_type=0 & m2_flag=1 & m1_flag=1 & f_reg; op_m1_b { f_reg = &op_m1_b; }
:MOVEA.b f_reg_b, op_m0_w is op=0x40; f_type=0 & m2_flag=0 & m1_flag=0 & f_reg_b; op_m0_w { op_m0_w = 0; }
:MOVEA.b f_reg_b, op_m1_w is op=0x40; f_type=0 & m2_flag=0 & m1_flag=1 & f_reg_b; op_m1_w { op_m1_w = 0; }
# F2 format
:MOVEA.b op_m0_b, op2_m0_w is op=0x40; f_type=1 & m1_flag=0 & m2_flag=0; op_m0_b; op2_m0_w { op2_m0_w = &op_m0_b; }
:MOVEA.b op_m0_b, op2_m1_w is op=0x40; f_type=1 & m1_flag=0 & m2_flag=1; op_m0_b; op2_m1_w { op2_m1_w = &op_m0_b; }
:MOVEA.b op_m1_b, op2_m0_w is op=0x40; f_type=1 & m1_flag=1 & m2_flag=0; op_m1_b; op2_m0_w { op2_m0_w = &op_m1_b; }
:MOVEA.b op_m1_b, op2_m1_w is op=0x40; f_type=1 & m1_flag=1 & m2_flag=1; op_m1_b; op2_m1_w { op2_m1_w = &op_m1_b; }

