:MOVEA.h op_m0_h, f_reg is op=0x42; f_type=0 & m2_flag=1 & m1_flag=0 & f_reg; op_m0_h { f_reg = &op_m0_h; }
:MOVEA.h op_m1_h, f_reg is op=0x42; f_type=0 & m2_flag=1 & m1_flag=1 & f_reg; op_m1_h { f_reg = &op_m1_h; }
